#!/usr/bin/env sh
# Pre-commit hook for zellij-tab-jump.
# Runs the same checks CI does so we don't push broken commits.
# Enable with: just install-hooks  (sets core.hooksPath=hooks)

set -e

if ! command -v just >/dev/null 2>&1; then
    echo "pre-commit: 'just' not found in PATH; skipping checks." >&2
    exit 0
fi

just check
